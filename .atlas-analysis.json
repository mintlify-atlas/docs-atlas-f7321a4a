  "keyFeatures": [
    "Push local HTML pages, posts, and templates to WordPress",
    "Fetch remote WordPress content to local files",
    "Diff-based merge conflict resolution",
    "Build system that inlines components and assets into dist HTML",
    "Image upload and CDN URL caching via manifest",
    "HMAC-SHA256 signed API authentication",
    "Incremental sync via MD5 hash manifest"
  ],
  "publicApiSurface": [
    "faisanbridge push [--force]",
    "faisanbridge fetch",
    "faisanbridge merge",
    "faisanbridge build",
    "faisanbridge status",
